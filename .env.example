# Option A: Standard fields
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shopzone
DB_USER=root
DB_PASS=your_password
DB_SSL=false

# Option B: Direct service URI (Aiven/MySQL URI). If set, DB_HOST may be ignored.
# DB_SERVICE_URI=mysql://user:pass@host:port/dbname?ssl-mode=REQUIRED

# Cloudinary (signed upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=shopzone

# Optional alias names (if you prefer these variable names)
# PERMANENT_CLOUD_NAME=your_cloud_name
# PERMANENT_CLOUD_API_KEY=your_api_key
# PERMANENT_CLOUD_API_SECRET=your_api_secret
